---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center">
      <p class="text-8xl font-bold text-gradient mb-4">404</p>
      <h1 class="text-2xl font-bold mb-4">Page Not Found</h1>
      <p class="text-text-secondary mb-8">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/en/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-brand-accent text-bg-primary font-semibold hover:brightness-110 transition-all">
        Go Home
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</BaseLayout>
