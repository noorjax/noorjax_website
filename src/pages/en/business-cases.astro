const publicModels = [
  { title: 'AnyLogic Cloud Public Models', url: 'https://cloud.anylogic.com/models?public=true&customSearchType=USER&customSearchData=5d461b39-ed33-4b3e-99f0-086dc344e0ce' },
  { title: 'Car Parking Demo Model', url: '/en/simulation-services/' },
  { title: 'Omniverse AnyLogic Integration', url: 'https://youtu.be/48XJyzxU9aQ' },
];

const studentWork = [
  { title: 'Using an Epidemiological Model to Measure Advertising Campaign Impact', url: 'https://www.linkedin.com/pulse/using-epidemiological-model-measure-advertising-impact-rodriguez/' },
  { title: 'Managing complex adaptive systems: A resource/agent qualitative modelling perspective', url: 'https://strathprints.strath.ac.uk/73611/1/Kazakov_etal_EJOR_2020_Managing_complex_adaptive_systems.pdf' },
  { title: 'A Machine Learning Approach on Earthmoving Fleet Selection', url: 'https://link.springer.com/chapter/10.1007/978-981-16-2377-6_75' },
  { title: 'The Case for RFID-Enabled Traceability in Cash Movements', url: 'https://www.mdpi.com/2674-1032/2/2/20' },
