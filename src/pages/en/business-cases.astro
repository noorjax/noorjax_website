const whitePapers = [
  { title: 'Simulation and Reinforcement Learning for Flexible Manufacturing Systems', url: '/documents/assembly-line-RL.pdf' },
  { title: 'A Discovery on Process Improvement Opportunities on a Covid PCR Test Laboratory', url: '/documents/discovery-process-Covid-Lab.pdf' },
  { title: 'East-West Warehouse Highway Traffic', url: '/documents/Warehouse-Management-Traffic-Analysis.pdf' },
  { title: 'Optimizing the Assignment of Parcels to Trays on a Tilt-Tray Conveyor System', url: '/documents/production-line-Tilt-Tray-Conveyors.pdf' },
  { title: 'Chronic Patient Scheduling Through Simulations', url: '/documents/Chronic-Patient-Scheduling-Through-Simulations.pdf' },
];

const conferencePresentations = [
  { title: 'Impact of Power and CO2 Emissions on Parking Sustainability', venue: 'EuroSim 2023', url: 'https://link.springer.com/chapter/10.1007/978-3-031-68435-7_4' },
  { title: 'Simulation and Reinforcement Learning for Flexible Manufacturing Systems', venue: 'AnyLogic Conference', url: 'https://www.youtube.com/watch?v=Oi7VzpWXaxM' },
  { title: 'Modeling Social Behavior on Energy Consumption', venue: 'AnyLogic Conference', url: 'https://www.youtube.com/watch?v=5PolsyfP6V0' },
  { title: 'Optimizing the Assignment of Parcels to Trays on a Tilt-Tray Conveyor System', venue: 'AnyLogic Conference', url: 'https://www.youtube.com/watch?v=c8NeGQcdvTU' },
  { title: 'Warehouse Highway Congestion - AnyLogic vs Excel', venue: 'AnyLogic Conference', url: 'https://www.youtube.com/watch?v=rwwEtdCZHkU' },
  { title: 'Studying the Impact of UAVs Adoption on Construction Safety', venue: 'Academic', url: 'https://youtu.be/CEzHZmOaJ_g' },
  { title: 'Custom Optimization Experiment with Confidence Intervals vs OptQuest', venue: 'IEEE', url: 'https://ieeexplore.ieee.org/document/11017060' },
  { title: 'Pharmaceutical Lab Expansion Amid Uncertainty of Future Processes', venue: 'AnyLogic Conference', url: 'https://www.youtube.com/watch?v=dLyJhboJSUA' },
];

const articles = [
  { title: 'The System Dynamics Conference From the Perspective of a Multi-Method Simulations Developer', url: 'https://systemdynamics.org/the-system-dynamics-conference-from-the-perspective-of-a-multi-method-simulations-developer/' },
  { title: 'Are rich and detailed manufacturing simulation models suitable for Lean Six Sigma training?', url: 'https://www.linkedin.com/pulse/rich-detailed-manufacturing-simulation-models-suitable-felipe-haro-af78f/' },
  { title: 'A failed simulation – and how AI could have saved it', url: 'https://www.linkedin.com/pulse/failed-simulation-how-ai-could-have-saved-felipe-haro-ft0df/' },
  { title: 'The art of simplifying', url: 'https://www.linkedin.com/pulse/art-simplifying-felipe-haro-zwzue/' },
  { title: 'Understanding When AI Helps Simulation Modelers ... And When It Doesn\'t', url: 'https://www.linkedin.com/pulse/understanding-when-ai-helps-simulation-modelers-doesnt-felipe-haro-3qivf' },
  { title: 'General Equilibrium Model (GEM) vs System Dynamics (SD)', url: 'https://www.linkedin.com/pulse/general-equilibrium-model-gem-vs-system-dynamics-sd-felipe-haro-llgxf' },
