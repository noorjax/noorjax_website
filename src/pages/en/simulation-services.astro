---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/common/PageHero.astro';
---

<PageLayout title="Car Parking Simulation Model Demo" description="See what to expect on a simulation project — interactive model, data dashboard, and video walkthrough.">
  <PageHero
    title="Car Parking Simulation Model Demo"
    subtitle="What to expect on a simulation project: the simulation model, data analysis, and strategic insights that help stakeholders make confident decisions."
  />
  <section class="py-(--spacing-section)">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">

        <!-- Video Walkthrough -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold mb-6">Video Walkthrough</h3>
          <p class="text-text-secondary mb-6">
            Watch the video below to understand the model before playing with the dashboard parameters and simulation.
          </p>
          <div class="aspect-video max-h-[70vh] rounded-2xl overflow-hidden border border-border-default shadow-lg">
            <iframe
              src="https://www.youtube.com/embed/tF1X5N9ffT8"
              title="Car Parking Simulation Model Demo"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="w-full h-full"
              loading="lazy"
            ></iframe>
          </div>
        </div>

        <!-- The Model -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold mb-4">The Model</h3>
          <p class="text-text-secondary leading-relaxed mb-6">
            This model consists of a car parking building with 7 levels and 2 types of floors, featuring automated elevators and conveyor-platforms that move cars from a waiting area to a parking spot according to space availability. When a car is requested to leave, the automated system redistributes blocking cars to retrieve it. The objective is to test multiple scenarios for car arrival and scheduling to understand building utilization, waiting times, and other KPIs.
          </p>
          <div class="aspect-[4/3] max-h-[70vh] rounded-2xl overflow-hidden border border-border-default shadow-lg bg-bg-secondary">
            <iframe
              src="https://cloud.anylogic.com/assets/embed?modelId=daa6b43c-284d-4c79-8d6b-e02bf2295a77"
              title="AnyLogic Car Parking Simulation"
              class="w-full h-full"
              loading="lazy"
            ></iframe>
          </div>
        </div>

        <!-- Analysis Dashboard -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold mb-4">Analysis Dashboard</h3>
          <div class="bg-bg-secondary rounded-2xl p-6 sm:p-8 border border-border-default mb-6">
            <p class="text-text-secondary mb-4">The dashboard shows metrics that help with:</p>
            <ul class="grid grid-cols-1 sm:grid-cols-3 gap-3">
              {['Model Validation', 'Strategy Implementation', 'Scenario Comparison'].map((item) => (
                <li class="flex items-center gap-2 text-text-primary font-medium">
                  <svg class="w-5 h-5 text-brand-green shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="aspect-[16/10] max-h-[70vh] rounded-2xl overflow-hidden border border-border-default shadow-lg bg-bg-secondary">
            <iframe
              src="https://app.powerbi.com/view?r=eyJrIjoiYjUxNWRkMTMtMzQ0ZS00MjAwLWE4MzAtODRmYzhjODQ3YzY2IiwidCI6IjRiNGI5ZWQ3LTMzNTUtNDIwNS05YjRiLTFhOTY5M2Q3ZDA3ZiJ9"
              title="Power BI Dashboard"
              class="w-full h-full"
              loading="lazy"
            ></iframe>
          </div>
        </div>

        <!-- Omniverse Integration -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold mb-6">Omniverse AnyLogic Integration</h3>
          <div class="aspect-video max-h-[70vh] rounded-2xl overflow-hidden border border-border-default shadow-lg">
            <iframe
              src="https://www.youtube.com/embed/u0ZJ2zPa9e4"
              title="Omniverse AnyLogic Integration"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="w-full h-full"
              loading="lazy"
            ></iframe>
          </div>
        </div>

        <!-- Bottom CTA -->
        <div class="text-center">
          <p class="text-text-secondary mb-6">Want a simulation like this for your project?</p>
          <a href="/en/contact/" class="btn-primary text-base px-8 py-4">
            Become a Client
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
    </div>
  </section>
</PageLayout>
