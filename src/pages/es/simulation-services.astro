---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/common/PageHero.astro';
---

<PageLayout title="Demo de Simulación AnyLogic — Qué Esperar" description="Descubre qué esperar de un proyecto de simulación AnyLogic — modelo interactivo, dashboard de datos y recorrido en video por Noorjax Consulting.">
  <PageHero
    title="Demo del Modelo de Simulación de Estacionamiento"
    subtitle="Qué esperar en un proyecto de simulación: el modelo de simulación, análisis de datos e insights estratégicos que ayudan a los stakeholders a tomar decisiones con confianza."
  />
  <section class="py-(--spacing-section)">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">

        <!-- Video Walkthrough -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold mb-6">Video Explicativo</h3>
          <p class="text-text-secondary mb-6">
            Mira el video a continuación para entender el modelo antes de jugar con los parámetros del panel y la simulación.
          </p>
          <div class="aspect-video max-h-[70vh] rounded-2xl overflow-hidden border border-border-default shadow-lg">
            <iframe
              src="https://www.youtube.com/embed/tF1X5N9ffT8"
              title="Demo del Modelo de Simulación de Estacionamiento"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="w-full h-full"
              loading="lazy"
            ></iframe>
          </div>
        </div>

        <!-- The Model -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold mb-4">El Modelo</h3>
          <p class="text-text-secondary leading-relaxed mb-6">
            Este modelo consiste en un edificio de estacionamiento con 7 niveles y 2 tipos de pisos, con ascensores automatizados y plataformas transportadoras que mueven los autos desde un área de espera hasta un lugar de estacionamiento según la disponibilidad de espacio. Cuando se solicita la salida de un auto, el sistema automatizado redistribuye los autos que bloquean para recuperarlo. El objetivo es probar múltiples escenarios de llegada y programación de autos para entender la utilización del edificio, tiempos de espera y otros KPIs.
          </p>
          <div class="aspect-[4/3] max-h-[70vh] rounded-2xl overflow-hidden border border-border-default shadow-lg bg-bg-secondary">
            <iframe
              src="https://cloud.anylogic.com/assets/embed?modelId=daa6b43c-284d-4c79-8d6b-e02bf2295a77"
              title="AnyLogic Car Parking Simulation"
              class="w-full h-full"
              loading="lazy"
            ></iframe>
          </div>
        </div>

        <!-- Analysis Dashboard -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold mb-4">Panel de Análisis</h3>
          <div class="bg-bg-secondary rounded-2xl p-6 sm:p-8 border border-border-default mb-6">
            <p class="text-text-secondary mb-4">El panel muestra métricas que ayudan con:</p>
            <ul class="grid grid-cols-1 sm:grid-cols-3 gap-3">
              {['Validación del Modelo', 'Implementación de Estrategia', 'Comparación de Escenarios'].map((item) => (
                <li class="flex items-center gap-2 text-text-primary font-medium">
                  <svg class="w-5 h-5 text-brand-green shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="aspect-[16/10] max-h-[70vh] rounded-2xl overflow-hidden border border-border-default shadow-lg bg-bg-secondary">
            <iframe
              src="https://app.powerbi.com/view?r=eyJrIjoiYjUxNWRkMTMtMzQ0ZS00MjAwLWE4MzAtODRmYzhjODQ3YzY2IiwidCI6IjRiNGI5ZWQ3LTMzNTUtNDIwNS05YjRiLTFhOTY5M2Q3ZDA3ZiJ9"
              title="Power BI Dashboard"
              class="w-full h-full"
              loading="lazy"
            ></iframe>
          </div>
        </div>

        <!-- Omniverse Integration -->
        <div class="mb-16">
          <h3 class="text-2xl font-bold mb-6">Integración Omniverse con AnyLogic</h3>
          <div class="aspect-video max-h-[70vh] rounded-2xl overflow-hidden border border-border-default shadow-lg">
            <iframe
              src="https://www.youtube.com/embed/u0ZJ2zPa9e4"
              title="Omniverse AnyLogic Integration"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="w-full h-full"
              loading="lazy"
            ></iframe>
          </div>
        </div>

        <!-- Bottom CTA -->
        <div class="text-center">
          <p class="text-text-secondary mb-6">¿Quieres una simulación como esta para tu proyecto?</p>
          <a href="/es/contact/" class="btn-primary text-base px-8 py-4">
            Agenda una Consulta
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
    </div>
  </section>
</PageLayout>
