---
import { Image } from 'astro:assets';
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/common/PageHero.astro';
import learnAnylogicImg from '../../assets/images/courses/learn-anylogic.png';
import otherCoursesImg from '../../assets/images/courses/other-courses.jpg';
import indonesiaImg from '../../assets/images/courses/indonesia-training.png';

const courseImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/courses/*',
  { eager: true }
);
function getCourseImage(file: string) {
  const key = `../../assets/images/courses/${file}`;
  return courseImages[key]?.default;
}

const courseTopics = [
  { name: 'Modelado Basado en Agentes', topics: ['Elementos de agentes', 'Diagramas de estado', 'JAVA'], image: 'agent-based.png' },
  { name: 'Eventos Discretos', topics: ['Librería de modelado de procesos', 'Marcado de espacio y GIS', 'Agentes de proceso'], image: 'discrete-events.png' },
  { name: 'Dinámica de Sistemas', topics: ['Dinámica de Sistemas en Vensim', 'Dinámica de Sistemas en AnyLogic', 'Diagramas de bucle causal'], image: 'system-dynamics.png' },
  { name: 'Librería de Tráfico Vial', topics: ['Modelado de tráfico', 'Semáforos y estacionamientos', 'Trucos especiales'], image: 'road-traffic.png' },
  { name: 'Librería de Peatones', topics: ['Modelado de peatones', 'El espacio peatonal', 'Trucos especiales'], image: 'pedestrians.png' },
  { name: 'Librería Ferroviaria', topics: ['Modelado de trenes', 'Vías férreas', 'Trucos especiales'], image: 'railway.png' },
  { name: 'Librería de Fluidos', topics: ['Modelado de dinámica de fluidos', 'Modelado de material a granel', 'Trucos especiales'], image: 'fluid.png' },
  { name: 'JAVA y Diagramas de Acción', topics: ['JAVA para AnyLogic', 'Conectividad (BD y Excel)', 'Aplicaciones de diagramas de acción'], image: 'java.png' },
  { name: 'Aplicaciones de AnyLogic', topics: ['Problemas del mundo real', 'Ejercicios para mejorar tus habilidades', 'Modelado Multi-Método'], image: 'applications.png' },
  { name: 'Librería de Manejo de Materiales', topics: ['Transportadores', 'Grúas', 'Cintas transportadoras'], image: 'material-handling.png' },
];
---

<PageLayout title="Cursos de AnyLogic y Formación en Simulación" description="Cursos de AnyLogic y formación en simulación — online, presencial o privada. Aprende eventos discretos, modelado basado en agentes, dinámica de sistemas y JAVA para AnyLogic.">
  <PageHero title="Cursos de Simulación" subtitle="Domina la simulación con nuestros cursos — disponibles presencial, online o como capacitación privada." />

  <section class="py-(--spacing-section)">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      <!-- AnyLogic Online Courses -->
      <div class="mb-20">
        <h2 class="text-3xl font-bold text-center mb-12">Cursos Online de AnyLogic</h2>
        <p class="text-center text-text-secondary mb-12 max-w-3xl mx-auto">Aprende AnyLogic desde casa con estos cursos 100% online</p>

        <!-- Learn AnyLogic Online -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
          <div class="rounded-2xl overflow-hidden border border-border-default">
            <Image src={learnAnylogicImg} alt="Learn AnyLogic Online" width={640} format="webp" class="w-full h-full object-cover" loading="lazy" decoding="async" />
          </div>
          <div class="flex flex-col justify-center">
            <h3 class="text-2xl font-bold mb-4">Aprende AnyLogic Online</h3>
            <p class="text-text-secondary leading-relaxed mb-4">
              Accede a un curso completo para aprender Java para AnyLogic, simulaciones de Eventos Discretos, modelado Basado en Agentes, Dinámica de Sistemas y mucho más usando AnyLogic. Suite de cursos online estructurados a tu propio ritmo.
            </p>
            <p class="text-text-secondary leading-relaxed mb-6">
              Los cursos incluyen JAVA, GIS, animaciones 2D y 3D, bases de datos, manejo de materiales, fluidos, peatones y mucho más. Con el apoyo de The AnyLogic Company.
            </p>
            <a href="https://noorjax.teachable.com/p/anylogic" target="_blank" rel="noopener noreferrer" class="btn-primary self-start">
              Acceder a Cursos Online
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Other Courses -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          <div class="flex flex-col justify-center order-2 lg:order-1">
            <h3 class="text-2xl font-bold mb-4">Otros Cursos</h3>
            <p class="text-text-secondary leading-relaxed mb-4">
              Desarrollamos otros cursos que te permitirán convertirte en un profesional de simulación más competente, creando cursos no solo en AnyLogic sino también en otros dominios. Encontrarás cursos de:
            </p>
            <ul class="space-y-2 mb-6">
              {['Autocad', 'FlexSim (Inglés y Español)', 'Simio (Inglés y Español)', 'Simudyne (Inglés y Español)'].map((item) => (
                <li class="flex items-center gap-2 text-text-secondary">
                  <svg class="w-4 h-4 text-brand-green shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
            <p class="text-sm text-text-tertiary italic mb-6">Estos cursos están diseñados para principiantes que quieren aprender cualquiera de estas herramientas de simulación o iniciarse con Autocad.</p>
            <a href="https://noorjax.teachable.com/" target="_blank" rel="noopener noreferrer" class="btn-secondary self-start">
              Ver Todos los Cursos
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
          <div class="rounded-2xl overflow-hidden border border-border-default order-1 lg:order-2">
            <Image src={otherCoursesImg} alt="Other Courses" width={640} format="webp" class="w-full h-full object-cover" loading="lazy" decoding="async" />
          </div>
        </div>
      </div>

      <div class="section-divider mb-20"></div>

      <!-- Free Learning Resources -->
      <div class="mb-20">
        <h2 class="text-3xl font-bold text-center mb-8">Recursos de Aprendizaje Gratuitos</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <a href="https://www.anylogic.com/blog/reusable-anylogic-agents-scale-simulation-projects-with-modular-models/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 bg-bg-secondary rounded-xl p-5 border border-border-default hover:border-brand-teal/30 transition-all hover:shadow-md group">
            <svg class="w-5 h-5 text-brand-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
            <span class="text-sm font-medium text-text-primary group-hover:text-brand-teal transition-colors">Reusable AnyLogic Agents</span>
          </a>
          <a href="https://www.anylogic.com/blog/simulation-project-life-cycle-webinar-follow-up/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 bg-bg-secondary rounded-xl p-5 border border-border-default hover:border-brand-teal/30 transition-all hover:shadow-md group">
            <svg class="w-5 h-5 text-brand-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
            <span class="text-sm font-medium text-text-primary group-hover:text-brand-teal transition-colors">The Simulation Project Lifecycle</span>
          </a>
          <a href="https://www.youtube.com/channel/UC_cNzjQJG9W2VTjVE2-DvrA" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 bg-bg-secondary rounded-xl p-5 border border-border-default hover:border-brand-teal/30 transition-all hover:shadow-md group">
            <svg class="w-5 h-5 text-red-500 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" /></svg>
            <span class="text-sm font-medium text-text-primary group-hover:text-brand-teal transition-colors">Noorjax YouTube Channel</span>
          </a>
        </div>
      </div>

      <div class="section-divider mb-20"></div>

      <!-- Partner Courses -->
      <div class="mb-20">
        <h2 class="text-3xl font-bold text-center mb-8">Cursos de Socios</h2>
        <div class="max-w-md mx-auto">
          <a href="https://benjamin-schumann.com/link/HPXtQK/NOORJAX?url=https%3A%2F%2Fbenjamin-schumann.com%2Fcourse%3Fcourseid%3Dgithub-for-anylogic" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 bg-bg-secondary rounded-xl p-5 border border-border-default hover:border-brand-teal/30 transition-all hover:shadow-md group">
            <svg class="w-5 h-5 text-brand-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
            <span class="text-sm font-medium text-text-primary group-hover:text-brand-teal transition-colors">GitHub for AnyLogic — by Benjamin Schumann</span>
          </a>
        </div>
      </div>

      <div class="section-divider mb-20"></div>

      <!-- AnyLogic Private Courses -->
      <div class="mb-20">
        <h2 class="text-3xl font-bold text-center mb-4">Cursos Privados de AnyLogic</h2>
        <p class="text-center text-text-secondary italic mb-12 max-w-2xl mx-auto">Acelera tu curva de aprendizaje</p>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
          <div>
            <p class="text-text-secondary leading-relaxed mb-4">
              Ya seas un principiante que quiere aprender lo básico, o alguien que necesita apoyo con un proyecto demasiado difícil de manejar, podemos ayudarte.
            </p>
            <p class="text-text-secondary leading-relaxed mb-4">
              Hemos realizado cursos por Zoom para sesiones 1 a 1 con tareas y asignaciones, así como capacitaciones presenciales para hasta 22 estudiantes simultáneamente. No hay restricciones. Si tienes un interés especial, podemos adaptarnos.
            </p>
            <p class="text-text-secondary leading-relaxed mb-6">
              Tenemos un horario flexible para capacitaciones basado en tus necesidades y la industria en la que trabajas.
            </p>
            <a href="/es/contact/" class="btn-primary">
              Enviar un Mensaje
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </a>
          </div>
          <div>
            <div class="rounded-2xl overflow-hidden border border-border-default">
              <Image src={indonesiaImg} alt="AnyLogic course in Tangerang, Indonesia" width={640} format="webp" class="w-full object-cover" loading="lazy" decoding="async" />
            </div>
            <p class="text-xs text-text-tertiary italic text-center mt-2">AnyLogic course in Tangerang, Indonesia</p>
          </div>
        </div>
      </div>

      <div class="section-divider mb-20"></div>

      <!-- Training Topics -->
      <div class="mb-20">
        <h2 class="text-3xl font-bold text-center mb-12">Temas de Capacitación</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {courseTopics.map((course) => (
            <div class="bg-bg-secondary rounded-2xl border border-border-default hover:border-brand-teal/30 transition-all hover:shadow-md overflow-hidden">
              <div class="aspect-[16/10] overflow-hidden">
                {(() => {
                  const img = getCourseImage(course.image);
                  return img ? (
                    <Image src={img} alt={course.name} width={480} format="webp" class="w-full h-full object-cover" loading="lazy" decoding="async" />
                  ) : null;
                })()}
              </div>
              <div class="p-6">
                <h3 class="text-lg font-bold mb-3">{course.name}</h3>
                <ul class="space-y-1.5">
                  {course.topics.map((topic) => (
                    <li class="flex items-center gap-2 text-sm text-text-secondary">
                      <svg class="w-4 h-4 text-brand-green shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      {topic}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center">
        <p class="text-lg text-text-secondary italic mb-6">¿Estás listo para que tú o tu equipo empiecen a aprender AnyLogic?</p>
        <a href="/es/contact/" class="btn-primary text-base px-8 py-4">
          Enviar un Mensaje
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</PageLayout>
