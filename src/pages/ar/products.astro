---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/common/PageHero.astro';

const products = [
  { name: 'JUNIT6 لـ AnyLogic', description: 'مكتبة للعمل مع اختبارات الوحدة باستخدام JUNIT6 في نماذج AnyLogic الخاصة بك.', type: 'مكتبة', image: 'junit6.png', url: 'https://github.com/noorjax/junit6-for-anylogic/' },
  { name: 'التحسين بفترات الثقة', description: 'إنشاء تجربة تحسين بفترات ثقة في نموذج AnyLogic الخاص بك. يعمل مع PLE ويمكن تصديره كملف تنفيذي.', type: 'مكتبة', image: 'optimization-ci.webp', url: '/ar/blog/optimization-with-confidence-intervals/' },
  { name: 'تجربة مونتي كارلو', description: 'مكتبة للعمل مع فترات الثقة في نموذج AnyLogic الخاص بك. تعمل مع PLE.', type: 'مكتبة', image: 'monte-carlo.png', url: '/ar/blog/monte-carlo-with-confidence-intervals/' },
  { name: 'مكتبة الناقلات الفرز', description: 'مكتبة AnyLogic مخصصة لشبكات الناقلات التي تفرز العملاء وتتصل بمصادر خارجية للأولويات والتوجيه. مبنية من ملف Excel.', type: 'مكتبة', image: 'sorting-conveyors.webp', url: '/ar/blog/sorting-conveyors-library/' },
  { name: 'مكتبة رافعة التكديس (ASRS)', description: 'مكتبة رافعة تكديس لإنشاء أنظمة التخزين والاسترجاع الآلية (ASRS) لـ AnyLogic.', type: 'مكتبة', image: 'stacker-crane.webp', url: '/ar/blog/pallet-crane-library/' },
  { name: 'مكتبة مجموعة المصاعد', description: 'مكتبة AnyLogic مخصصة لاستخدام مجموعة من المصاعد مع مكتبة نمذجة العمليات أو المشاة.', type: 'مكتبة', image: 'elevator.webp', url: '/ar/blog/elevator-group-library/' },
  { name: 'مكتبة الذراع الروبوتية', description: 'مكتبة مجانية لاستخدام ذراع روبوتية في نماذج AnyLogic الخاصة بك. مميزة في مدونة AnyLogic.', type: 'مكتبة', image: 'robotic-arm.webp', url: '/ar/blog/robotic-arm-library/' },
  { name: 'مساعد تحليل البيانات ChatGPT', description: 'مكتبة مجانية لاستخدام ChatGPT لتحليل البيانات في نماذج AnyLogic الخاصة بك.', type: 'مكتبة', image: 'chatgpt.webp', url: 'https://github.com/noorjax/Chat-GPT-Data-Analyst' },
  { name: 'دورات المحاكاة الشاملة', description: 'مجموعة كاملة من الدورات لتعلم نمذجة المحاكاة، من الأساسيات إلى المواضيع المتقدمة.', type: 'دورة', image: 'courses.png', url: 'https://noorjax.teachable.com' },
];
---

<PageLayout title="المنتجات" description="مكتبات وأدوات ودورات AnyLogic من نورجاكس للاستشارات.">
  <PageHero
    title="المنتجات"
    subtitle="مكتبات وأدوات ودورات AnyLogic من فريقنا لتوسيع قدرات المحاكاة."
  />
  <section class="py-(--spacing-section)">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      <!-- Products grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {products.map((product) => (
          <a href={product.url} {...(product.url.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})} class="bg-bg-secondary rounded-2xl border border-border-default hover:border-brand-teal/30 transition-all hover:shadow-lg group block overflow-hidden flex flex-col">
            <div class="aspect-[16/10] overflow-hidden">
              <img
                src={`/images/products/${product.image}`}
                alt={product.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-6 flex flex-col flex-1">
              <div class="mb-3">
                <span class:list={[
                  'text-xs font-medium px-2.5 py-1 rounded-full',
                  product.type === 'مكتبة'
                    ? 'bg-brand-teal/10 text-brand-teal'
                    : 'bg-brand-green/10 text-brand-green',
                ]}>
                  {product.type}
                </span>
              </div>
              <h3 class="text-lg font-bold mb-2 text-text-primary group-hover:text-brand-teal transition-colors">{product.name}</h3>
              <p class="text-sm text-text-secondary leading-relaxed flex-1">{product.description}</p>
            </div>
          </a>
        ))}
      </div>

      <!-- CTA -->
      <div class="text-center mt-16">
        <p class="text-text-secondary mb-6">مهتم بمنتجاتنا أو تحتاج مكتبة مخصصة؟</p>
        <a href="/ar/contact/" class="btn-primary text-base px-8 py-4">
          كن عميلاً
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</PageLayout>
