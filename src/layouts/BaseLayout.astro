---
import '../styles/global.css';
import { getLocaleFromUrl, getAlternateUrl, t, type Locale } from '../i18n';
import { SITE } from '../lib/constants';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const locale = getLocaleFromUrl(Astro.url);
const i18n = t(locale);
const { title, description, image } = Astro.props;

const pageTitle = title ? `${title} | ${SITE.name}` : `${SITE.name} — ${i18n.site.description}`;
const pageDescription = description || i18n.site.description;
const ogImage = image || '/images/og-default.jpg';
const canonicalUrl = new URL(Astro.url.pathname, SITE.url);
const alternateEn = new URL(getAlternateUrl(Astro.url, 'en'), SITE.url);
const alternateEs = new URL(getAlternateUrl(Astro.url, 'es'), SITE.url);
const alternateAr = new URL(getAlternateUrl(Astro.url, 'ar'), SITE.url);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- i18n alternates -->
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="es" href={alternateEs} />
    <link rel="alternate" hreflang="ar" href={alternateAr} />
    <link rel="alternate" hreflang="x-default" href={alternateEn} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={new URL(ogImage, SITE.url)} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={locale === 'es' ? 'es_CL' : locale === 'ar' ? 'ar_SA' : 'en_US'} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={new URL(ogImage, SITE.url)} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/logo/Noorjax-icon-png1.png" />

    <!-- Fonts: Self-hosted Inter -->
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/inter-latin.woff2" />

    <!-- Client-side routing (View Transitions) -->
    <ClientRouter />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ProfessionalService',
      name: SITE.name,
      description: pageDescription,
      url: SITE.url,
      email: SITE.email,
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Ahtri 12-512',
        addressLocality: 'Tallinn',
        postalCode: '10151',
        addressCountry: 'EE',
      },
      sameAs: [SITE.linkedin],
      founder: {
        '@type': 'Person',
        name: 'Felipe Haro',
      },
      foundingDate: '2017',
    })} />
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />
  </body>
</html>
