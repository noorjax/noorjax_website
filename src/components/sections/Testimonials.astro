---

<section class="py-(--spacing-section) bg-bg-primary">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">
        {locale === 'en' ? 'What People Say' : locale === 'es' ? 'Lo Que Dicen Nuestros Clientes' : 'ماذا يقول الناس'}
      </h2>
      <p class="text-text-secondary">
        {locale === 'en' ? 'Testimonials from clients and collaborators worldwide.' : locale === 'es' ? 'Testimonios de clientes y colaboradores de todo el mundo.' : 'شهادات من عملاء ومتعاونين حول العالم.'}
      </p>
    </div>

    <!-- Carousel container -->
    <div class="relative" id="testimonial-carousel">
      <div class="overflow-hidden">
        <div class="flex transition-transform duration-500 ease-in-out will-change-transform" id="testimonial-track">
          {items.map((t, i) => (
            <div class="shrink-0 grow-0 px-3" style={`width: ${100 / items.length}%`} data-index={i}>
              <div class="bg-bg-secondary rounded-2xl p-6 border border-border-default h-full flex flex-col">
                <div class="text-brand-green text-lg mb-3">{stars(t.rating)}</div>
                <blockquote class="text-sm text-text-secondary leading-relaxed flex-1 italic">
                  "{t.quote}"
                </blockquote>
                <div class="mt-4 pt-4 border-t border-border-default">
                  <p class="font-bold text-text-primary text-sm">{t.name}</p>
                  {t.position && <p class="text-xs text-text-tertiary">{t.position}</p>}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Navigation buttons -->
      <div class="flex items-center justify-center gap-4 mt-8">
        <button
          id="testimonial-prev"
          class="w-10 h-10 rounded-full border border-border-default flex items-center justify-center text-text-secondary hover:text-brand-teal hover:border-brand-teal transition-colors"
          aria-label="Previous"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <span class="text-sm text-text-tertiary" id="testimonial-counter">1 / {items.length}</span>
        <button
          id="testimonial-next"
          class="w-10 h-10 rounded-full border border-border-default flex items-center justify-center text-text-secondary hover:text-brand-teal hover:border-brand-teal transition-colors"
          aria-label="Next"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  function initTestimonials() {
    var track = document.getElementById('testimonial-track');
    var prevBtn = document.getElementById('testimonial-prev');
    var nextBtn = document.getElementById('testimonial-next');
    var counter = document.getElementById('testimonial-counter');
    if (!track || !prevBtn || !nextBtn || !counter) return;

    var total = track.children.length;
    var page = 0;

    function getVisible() {
      return window.innerWidth >= 1024 ? 3 : window.innerWidth >= 768 ? 2 : 1;
    }

    function update() {
      var visible = getVisible();
      var totalPages = Math.ceil(total / visible);
      if (page >= totalPages) page = totalPages - 1;
      if (page < 0) page = 0;
      var startIndex = page * visible;
      if (startIndex + visible > total) startIndex = total - visible;
      var offset = (startIndex / total) * 100;
      track.style.cssText = 'width:' + (total / visible) * 100 + '%;transform:translateX(-' + offset + '%)';
      counter.textContent = (page + 1) + ' / ' + totalPages;
    }

    prevBtn.onclick = function() { page--; update(); };
    nextBtn.onclick = function() { page++; update(); };
    window.addEventListener('resize', update);
    update();
  }

  initTestimonials();
  document.addEventListener('astro:after-swap', initTestimonials);
</script>
