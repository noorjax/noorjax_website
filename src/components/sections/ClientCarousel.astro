---
import { Image } from 'astro:assets';
import { getLocaleFromUrl } from '../../i18n';

const locale = getLocaleFromUrl(Astro.url);

const clientImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/clients/*',
  { eager: true }
);

const clients = [
  { name: 'Amazon', file: 'amazon-logo.jpg' },
  { name: 'McKinsey', file: 'MCKINSEY-CO-LOGO.jpg' },
  { name: 'Walmart', file: 'Walmart-Logo-PNG-Transparent.png' },
  { name: 'Kimberly Clark', file: 'kimberly-clark.jpg' },
  { name: 'Qatar Foundation', file: 'qatar-foundation.png' },
  { name: 'BlaBlacar', file: 'blablacar.jpg' },
  { name: 'Agrosuper', file: 'agrosuper.png' },
  { name: 'Magna', file: 'magna.png' },
  { name: 'Advisian', file: 'advisian.png' },
  { name: 'ADS', file: 'ADS.jpg' },
  { name: 'KAPSARC', file: 'kapsarc.png' },
  { name: 'Seriti', file: 'seriti.png' },
  { name: 'Nacala', file: 'nacala.png' },
  { name: 'Dept. of Transport', file: 'department-of-transport.png' },
  { name: 'Whiteshield', file: 'whiteshield.png' },
  { name: 'UCN', file: 'ucn.png' },
  { name: 'UHasselt', file: 'uhasselt.png' },
  { name: 'Maribor University', file: 'maribor-university.png' },
  { name: 'Cogsworth', file: 'cogsworth.png' },
  { name: 'KMC', file: 'kmc.png' },
  { name: 'St Onge', file: 'st-onge.png' },
  { name: 'Athena', file: 'athena.jpeg' },
  { name: 'Haiberg', file: 'haiberg.png' },
  { name: 'High Cap', file: 'high-cap.png' },
  { name: 'Millenial Venturing', file: 'millenial-venturing.png' },
  { name: 'Propan Raya', file: 'propan.png' },
  { name: 'Santa Rita', file: 'santarita.jpeg' },
  { name: 'Winspire', file: 'winspire.jpeg' },
  { name: 'Fielstone', file: 'fielstone.png' },
  { name: 'Murgo', file: 'murgo.png' },
  { name: 'Lean', file: 'Lean-Logo.png' },
  { name: 'Common Sense', file: 'common-sense.png' },
];

function getClientImage(file: string) {
  const key = `../../assets/images/clients/${file}`;
  return clientImages[key]?.default;
}
---

<div class="overflow-hidden py-8">
  <h2 class="text-2xl font-bold text-center mb-10">{locale === 'en' ? 'Some of The Companies We Worked With' : locale === 'es' ? 'Algunas de las Empresas con las que Trabajamos' : 'بعض الشركات التي عملنا معها'}</h2>

  <div class="carousel-track flex items-center gap-16">
    {clients.map((client) => {
      const img = getClientImage(client.file);
      return img ? (
        <div class="shrink-0">
          <Image
            src={img}
            alt={client.name}
            height={40}
            format="webp"
            class="h-8 sm:h-10 w-auto max-w-[120px] object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
            loading="lazy"
            decoding="async"
          />
        </div>
      ) : null;
    })}
    {clients.map((client) => {
      const img = getClientImage(client.file);
      return img ? (
        <div class="shrink-0" aria-hidden="true">
          <Image
            src={img}
            alt=""
            height={40}
            format="webp"
            class="h-8 sm:h-10 w-auto max-w-[120px] object-contain grayscale opacity-50"
            loading="lazy"
            decoding="async"
          />
        </div>
      ) : null;
    })}
  </div>
</div>

<style>
  .carousel-track {
    animation: scroll 50s linear infinite;
    width: max-content;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
