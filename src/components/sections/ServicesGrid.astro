---
import { getLocaleFromUrl, t } from '../../i18n';
import { SERVICES } from '../../lib/constants';

const locale = getLocaleFromUrl(Astro.url);
const i18n = t(locale);
const services = SERVICES[locale] || SERVICES['en'];
---

<section class="py-(--spacing-section) bg-bg-secondary">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">{i18n.services.title}</h2>
      <p class="text-text-secondary max-w-2xl mx-auto">{i18n.services.subtitle}</p>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      {services.map((service, idx) => {
        const enName = (SERVICES['en'][idx] || service).name;
        return (
          <a href={`/${locale}/business-cases/?service=${encodeURIComponent(enName)}`} class="group bg-bg-primary rounded-xl p-5 border border-border-default hover:border-brand-teal/30 transition-all duration-300 hover:-translate-y-1 hover:shadow-md cursor-pointer block">
            <div class="text-3xl mb-3">{service.icon}</div>
            <h3 class="text-sm font-semibold text-text-primary leading-tight">{service.name}</h3>
          </a>
        );
      })}
    </div>

    <!-- View all CTA -->
    <div class="text-center mt-12">
      <a
        href={`/${locale}/simulation-services/`}
        class="inline-flex items-center gap-2 text-brand-teal font-semibold hover:gap-3 transition-all"
      >
        {locale === 'en' ? 'See a Demo Project' : locale === 'es' ? 'Ver un Proyecto Demo' : 'شاهد مشروعاً تجريبياً'}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
