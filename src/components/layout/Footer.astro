---
import { getLocaleFromUrl, t } from '../../i18n';
import { SITE, NAV_LINKS } from '../../lib/constants';

const locale = getLocaleFromUrl(Astro.url);
const i18n = t(locale);
const links = NAV_LINKS[locale];
const year = new Date().getFullYear();
---

<footer class="dark-section border-t border-bg-dark-secondary mt-auto">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <img src="/images/logo/Noorjax-01.png" alt="Noorjax Consulting" class="h-10 w-auto brightness-0 invert mb-3" />
        <p class="mt-3 text-sm text-text-on-dark-muted max-w-xs">
          {i18n.footer.tagline}
        </p>
        <div class="mt-5 flex gap-4">
          <a
            href="https://www.linkedin.com/company/noorjax/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-on-dark-muted hover:text-brand-teal transition-colors"
            aria-label="LinkedIn"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
          <a
            href="https://www.youtube.com/@noorjaxconsulting"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-on-dark-muted hover:text-red-500 transition-colors"
            aria-label="YouTube"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
            </svg>
          </a>
          <a
            href={`mailto:${SITE.email}`}
            class="text-text-on-dark-muted hover:text-brand-teal transition-colors"
            aria-label="Email"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-sm font-semibold text-text-on-dark uppercase tracking-wider mb-4">
          {locale === 'en' ? 'Navigation' : locale === 'es' ? 'Navegación' : 'التنقل'}
        </h4>
        <ul class="space-y-2.5">
          {links.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-text-on-dark-muted hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-sm font-semibold text-text-on-dark uppercase tracking-wider mb-4">
          {i18n.nav.contact}
        </h4>
        <ul class="space-y-2.5 text-sm text-text-on-dark-muted">
          <li>
            <a href={`mailto:${SITE.email}`} class="hover:text-white transition-colors">
              {SITE.email}
            </a>
          </li>
          <li>
            <a href={SITE.calendly} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
              {locale === 'en' ? 'Book a meeting' : locale === 'es' ? 'Agenda una reunión' : 'احجز اجتماعاً'}
            </a>
          </li>
          <li class="text-text-on-dark-muted">{SITE.address}</li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-bg-dark-secondary flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-text-on-dark-muted">
        &copy; {year} {SITE.name}. {i18n.footer.rights}
      </p>
      <p class="text-xs text-text-on-dark-muted">
        {SITE.address}
      </p>
    </div>
  </div>
</footer>
