---
import { getLocaleFromUrl, getAlternateUrl, getOtherLocales, localeNames, t, type Locale } from '../../i18n';
import { SITE, NAV_LINKS } from '../../lib/constants';
import { Image } from 'astro:assets';
import logoImg from '../../assets/images/logo/Noorjax-01.png';

const locale = getLocaleFromUrl(Astro.url);
const i18n = t(locale);
const links = NAV_LINKS[locale];
const otherLocales = getOtherLocales(locale);

const flags: Record<string, { flag: string; label: string }> = {
  en: { flag: '🇬🇧', label: 'English' },
  es: { flag: '🇪🇸', label: 'Español' },
  ar: { flag: '🇸🇦', label: 'العربية' },
};
const currentFlag = flags[locale];
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-bg-primary border-b border-border-default shadow-sm"
  id="site-header"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between h-16 lg:h-18" aria-label="Main navigation">
      <!-- Logo -->
      <a href={`/${locale}/`} class="flex items-center shrink-0" aria-label={SITE.name}>
        <Image src={logoImg} alt="Noorjax Consulting" class="h-10 lg:h-12 w-auto" width={384} quality={90} format="webp" loading="eager" decoding="async" fetchpriority="high" />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-6">
        {links.map((link) => {
          const isContact = link.href.endsWith('/contact/');
          const isActive = Astro.url.pathname.startsWith(link.href) && link.href !== `/${locale}/`;
          return isContact ? (
            <a href={link.href} class="btn-primary text-xs px-4 py-2">
              {link.label}
            </a>
          ) : (
            <a
              href={link.href}
              class:list={[
                'text-sm font-medium transition-colors',
                isActive ? 'text-brand-teal font-semibold' : 'text-text-secondary hover:text-text-primary',
              ]}
            >
              {link.label}
            </a>
          );
        })}

        <!-- Social icons -->
        <div class="flex items-center gap-3 ml-2 pl-4 border-l border-border-default">
          <a href="https://www.linkedin.com/company/noorjax/" target="_blank" rel="noopener noreferrer" class="text-text-tertiary hover:text-brand-teal transition-colors" aria-label="LinkedIn">
            <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>
          </a>
          <a href="https://www.youtube.com/@noorjaxconsulting" target="_blank" rel="noopener noreferrer" class="text-text-tertiary hover:text-red-600 transition-colors" aria-label="YouTube">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" /></svg>
          </a>
        </div>

        <!-- Language Dropdown -->
        <div class="relative" id="lang-dropdown-desktop">
          <button
            class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-border-default text-sm text-text-secondary hover:text-text-primary hover:border-border-hover transition-all cursor-pointer"
            id="lang-btn-desktop"
            aria-expanded="false"
            aria-haspopup="true"
          >
            <span class="text-base leading-none">{currentFlag.flag}</span>
            <span class="font-medium">{currentFlag.label}</span>
            <svg class="w-3.5 h-3.5 transition-transform" id="lang-chevron-desktop" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div class="absolute right-0 top-full mt-1.5 w-44 bg-bg-primary border border-border-default rounded-xl shadow-lg overflow-hidden hidden z-50" id="lang-menu-desktop">
            {otherLocales.map((lang) => (
              <a
                href={getAlternateUrl(Astro.url, lang)}
                class="flex items-center gap-3 px-4 py-2.5 text-sm text-text-secondary hover:bg-brand-teal/5 hover:text-brand-teal transition-colors"
              >
                <span class="text-base leading-none">{flags[lang].flag}</span>
                <span>{flags[lang].label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Mobile Menu Toggle -->
      <button class="lg:hidden p-2 text-text-secondary hover:text-text-primary" id="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
        <svg class="w-6 h-6" id="menu-icon-open" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
        <svg class="w-6 h-6 hidden" id="menu-icon-close" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div class="lg:hidden hidden" id="mobile-menu">
    <div class="glass mx-4 mt-2 rounded-xl p-6 space-y-4 shadow-lg">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            'block text-base font-medium py-2 transition-colors',
            Astro.url.pathname.startsWith(link.href) && link.href !== `/${locale}/`
              ? 'text-brand-teal'
              : 'text-text-secondary hover:text-text-primary',
          ]}
        >
          {link.label}
        </a>
      ))}
      <div class="pt-4 border-t border-border-default">
        <div class="flex items-center gap-4 mb-4">
          <a href="https://www.linkedin.com/company/noorjax/" target="_blank" rel="noopener noreferrer" class="text-text-tertiary hover:text-brand-teal" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>
          </a>
          <a href="https://www.youtube.com/@noorjaxconsulting" target="_blank" rel="noopener noreferrer" class="text-text-tertiary hover:text-red-600" aria-label="YouTube">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" /></svg>
          </a>
        </div>
        <!-- Mobile Language Options -->
        <div class="flex flex-col gap-1">
          {otherLocales.map((lang) => (
            <a
              href={getAlternateUrl(Astro.url, lang)}
              class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-text-secondary hover:bg-brand-teal/5 hover:text-brand-teal transition-colors"
            >
              <span class="text-base leading-none">{flags[lang].flag}</span>
              <span>{flags[lang].label}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  function initHeader() {
    // Mobile menu
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (toggle && menu) {
      const newToggle = toggle.cloneNode(true);
      toggle.parentNode.replaceChild(newToggle, toggle);
      newToggle.addEventListener('click', () => {
        const isOpen = !menu.classList.contains('hidden');
        menu.classList.toggle('hidden');
        const openIcon = newToggle.querySelector('#menu-icon-open') || document.getElementById('menu-icon-open');
        const closeIcon = newToggle.querySelector('#menu-icon-close') || document.getElementById('menu-icon-close');
        openIcon?.classList.toggle('hidden');
        closeIcon?.classList.toggle('hidden');
        newToggle.setAttribute('aria-expanded', String(!isOpen));
      });
      menu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          menu.classList.add('hidden');
          document.getElementById('menu-icon-open')?.classList.remove('hidden');
          document.getElementById('menu-icon-close')?.classList.add('hidden');
        });
      });
    }

    // Language dropdown
    const btn = document.getElementById('lang-btn-desktop');
    const langMenu = document.getElementById('lang-menu-desktop');
    const chevron = document.getElementById('lang-chevron-desktop');
    if (btn && langMenu) {
      const newBtn = btn.cloneNode(true);
      btn.parentNode.replaceChild(newBtn, btn);
      const newChevron = newBtn.querySelector('#lang-chevron-desktop');
      newBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !langMenu.classList.contains('hidden');
        langMenu.classList.toggle('hidden');
        newChevron?.classList.toggle('rotate-180');
        newBtn.setAttribute('aria-expanded', String(!isOpen));
      });
      document.addEventListener('click', () => {
        langMenu.classList.add('hidden');
        newChevron?.classList.remove('rotate-180');
        newBtn.setAttribute('aria-expanded', 'false');
      });
    }
  }

  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>
